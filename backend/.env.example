# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/learning_platform

# JWT Authentication
JWT_SECRET=your-super-secret-key-min-32-characters-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider Selection: gemini | groq | openai
ACTIVE_AI=gemini

# AI API Keys (add at least one)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# App Settings
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
